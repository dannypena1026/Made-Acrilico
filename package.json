{
  "name": "made-acrilico",
  "version": "1.7.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./css/tailwind.input.css -o ./css/tailwind.css --minify",
    "build:js": "node scripts/build-js.mjs",
    "check:html": "html-validate \"*.html\"",
    "check:js": "node scripts/check-js.mjs",
    "check:project": "node scripts/check-project.mjs",
    "test": "node --test",
    "test:e2e": "playwright test",
    "dev": "node scripts/dev-server.mjs",
    "dev:worker": "npx --yes wrangler@4.113.0 dev --config worker/wrangler.jsonc --local --ip 0.0.0.0 --port 8787",
    "deploy:worker": "npx --yes wrangler@4.113.0 deploy --config worker/wrangler.jsonc"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "esbuild": "0.28.1",
    "html-validate": "10.4.0",
    "tailwindcss": "3.4.17"
  }
}
